# AVIAGENT environment — copy to .env before docker compose up

# Django auth
SECRET_KEY=change-me-in-production-aviagent-dev-key
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,auth,api,frontend

# Postgres
POSTGRES_USER=avia_user
POSTGRES_PASSWORD=avia_pass
POSTGRES_DB=avia_db
DATABASE_URL=postgresql://avia_user:avia_pass@postgres:5432/avia_db

# Mongo
MONGO_URI=mongodb://root:aviaroot@mongo:27017/avia_dev?authSource=admin
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=aviaroot

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=aviadmin
MINIO_SECRET_KEY=aviadmin123
MINIO_BUCKET=avia-data
MINIO_SECURE=false

# Qdrant
QDRANT_URL=http://qdrant:6333

# LLM — default provider (ollama | huggingface | gemini | openai | claude)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5-coder:7b

# Ollama (free, local — install separately: https://ollama.com)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Hugging Face (free tier — get token from https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# Google Gemini (paid — get key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# OpenAI (paid — get key from https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (paid — get key from https://console.anthropic.com/)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# CORS
CORS_ORIGINS=http://localhost:8091,http://127.0.0.1:8091
FRONTEND_URL=http://localhost:8091

# Service URLs (internal Docker network)
AUTH_SERVICE_URL=http://auth:8002
AI_SERVICE_URL=http://ai:8012
