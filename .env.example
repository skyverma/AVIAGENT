# AVIAGENT environment — copy to .env before docker compose up

# Django auth
SECRET_KEY=change-me-in-production-aviagent-dev-key
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,auth,api,frontend

# Postgres
POSTGRES_USER=avia_user
POSTGRES_PASSWORD=avia_pass
POSTGRES_DB=avia_db
DATABASE_URL=postgresql://avia_user:avia_pass@postgres:5432/avia_db

# Mongo
MONGO_URI=mongodb://root:aviaroot@mongo:27017/avia_dev?authSource=admin
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=aviaroot

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=aviadmin
MINIO_SECRET_KEY=aviadmin123
MINIO_BUCKET=avia-data
MINIO_SECURE=false

# Qdrant
QDRANT_URL=http://qdrant:6333

# ============================================================
# LLM PROVIDERS — only Hugging Face (free) + Gemini (paid) enabled
# ============================================================

# Default provider for everyone: huggingface | gemini
LLM_PROVIDER=huggingface
LLM_MODEL=deepseek-ai/DeepSeek-V3-0324

# Hugging Face (hosted, free tier) — token from https://huggingface.co/settings/tokens
# DeepSeek V3 on HF Inference Providers (free tier)
HUGGINGFACE_API_KEY=hf_your_token_here
HUGGINGFACE_MODEL=deepseek-ai/DeepSeek-V3-0324
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# Optional: direct DeepSeek API (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# Google Gemini (paid, smartest) — key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DEFAULT_MODEL=gemini-2.5-pro
# CORS
CORS_ORIGINS=http://localhost:8091,http://127.0.0.1:8091
FRONTEND_URL=http://localhost:8091

# Service URLs (internal Docker network)
AUTH_SERVICE_URL=http://auth:8002
AI_SERVICE_URL=http://ai:8012
