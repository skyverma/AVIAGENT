{
  "name": "aviadesktop",
  "version": "0.1.0",
  "description": "AviaAgent desktop shell (Electron)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aviagent.desktop",
    "productName": "AviaAgent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "en_US"
      ]
    }
  }
}
