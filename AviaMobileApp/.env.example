# Copy to .env before building APK — keys are baked into the app at build time.
# Users can override with their own key in Settings (optional).

# Free DeepSeek via Hugging Face (same as AVIAGENT docker backend)
VITE_DEFAULT_HF_API_KEY=hf_your_token_here
VITE_DEFAULT_LLM_PROVIDER=huggingface
VITE_DEFAULT_LLM_MODEL=deepseek-ai/DeepSeek-V3-0324

# Optional: direct DeepSeek API (platform.deepseek.com)
VITE_DEFAULT_DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# Optional: Gemini fallback baked into APK
VITE_DEFAULT_GEMINI_API_KEY=
